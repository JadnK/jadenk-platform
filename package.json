{
  "name": "jadenk-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter ./apps/* dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "start:web": "pnpm --filter web start -- --host 127.0.0.1 --port 3000",
    "start:api": "pnpm --filter api start",
    "start": "pnpm -r --parallel --filter web --filter api start"
  }
}